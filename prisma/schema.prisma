generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  passwordHash     String
  name             String?
  username         String?    @unique
  role             Role       @default(USER)
  status           UserStatus @default(ACTIVE)
  emailVerified    Boolean    @default(false)
  stripeAccountId  String?    @unique
  stripeOnboarded  Boolean    @default(false)
  payoutsEnabled   Boolean    @default(false)
  dailyVolume      Int        @default(0)
  monthlyVolume    Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  wallet              Wallet?
  transactions        Transaction[]
  payouts             Payout[]
  bankAccounts        BankAccount[]
  paymentLinks        PaymentLink[]
  kycProfile          KycProfile?
  securityLogs        SecurityLog[]
  auditLogs           AuditLog[]
  openBankingSessions OpenBankingSession[]
  invitationsSent     Invitation[]       @relation("InvitedBy")
  emailVerifications  EmailVerification[]

  @@index([email])
  @@index([username])
}

enum Role {
  ADMIN_OWNER
  ADMIN
  USER
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

model Invitation {
  id        String    @id @default(cuid())
  email     String
  role      Role      @default(USER)
  tokenHash String    @unique
  invitedBy String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  inviter User @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@index([email])
  @@index([tokenHash])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
}

model EmailLog {
  id                String   @id @default(cuid())
  toEmail           String
  subject           String
  template          String
  status            String   @default("SENT")
  providerMessageId String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([toEmail])
  @@index([template])
  @@index([createdAt])
}

model Wallet {
  id               String       @id @default(cuid())
  userId           String       @unique
  availableBalance Int          @default(0)
  pendingBalance   Int          @default(0)
  currency         String       @default("EUR")
  providerWalletId String?      @unique
  status           WalletStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

model Transaction {
  id                    String         @id @default(cuid())
  walletId              String
  userId                String
  type                  TxType
  status                TxStatus       @default(PENDING)
  amount                Int
  fees                  Int            @default(0)
  netAmount             Int            @default(0)
  currency              String         @default("EUR")
  paymentMethod         PaymentMethod?
  provider              String?
  providerTransactionId String?        @unique
  description           String?
  payerEmail            String?
  payerName             String?
  metadata              Json?
  failureReason         String?
  idempotencyKey        String?        @unique
  receiptSent           Boolean        @default(false)
  refundedAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([providerTransactionId])
}

enum TxType {
  PAYIN
  PAYOUT
  REFUND
  TRANSFER
  FEE
}

enum TxStatus {
  PENDING
  PROCESSING
  AUTHORIZED
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  REVOLUT_PAY
  PAYPAL
  BANK_TRANSFER
  SEPA
  OPEN_BANKING
}

model PaymentLink {
  id          String   @id @default(cuid())
  userId      String
  slug        String   @unique
  label       String   @default("Paiement")
  fixedAmount Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([slug])
}

model OpenBankingSession {
  id                String             @id @default(cuid())
  userId            String?
  transactionId     String?
  providerSessionId String?            @unique
  bankId            String?
  amount            Int
  currency          String             @default("EUR")
  status            OpenBankingStatus  @default(INITIATED)
  redirectUrl       String?
  callbackData      Json?
  payerEmail        String?
  payerName         String?
  errorMessage      String?
  expiresAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([providerSessionId])
  @@index([status])
}

enum OpenBankingStatus {
  INITIATED
  REDIRECTED
  AUTHORIZED
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

model Payout {
  id               String       @id @default(cuid())
  userId           String
  bankAccountId    String
  amount           Int
  fees             Int          @default(0)
  netAmount        Int          @default(0)
  currency         String       @default("EUR")
  status           PayoutStatus @default(PENDING)
  providerPayoutId String?      @unique
  idempotencyKey   String?      @unique
  estimatedArrival DateTime?
  failureReason    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([userId])
  @@index([status])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

model BankAccount {
  id                    String     @id @default(cuid())
  userId                String
  ibanMasked            String
  ibanEncrypted         String?
  bic                   String?
  holderName            String
  bankName              String?
  country               String     @default("FR")
  currency              String     @default("EUR")
  status                BankStatus @default(PENDING)
  isDefault             Boolean    @default(false)
  providerBankAccountId String?    @unique
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @default(now()) @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts Payout[]

  @@index([userId])
}

enum BankStatus {
  PENDING
  VERIFIED
  REJECTED
}

model KycProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  status          KycStatus @default(NOT_STARTED)
  level           String    @default("LIGHT")
  providerKycId   String?
  rejectionReason String?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VALIDATED
  REFUSED
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventType   String
  eventId     String    @unique
  payload     Json
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([eventId])
  @@index([processed])
}

model SecurityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  severity  String   @default("INFO")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([severity])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

// ─── GUARDIAN AI ─────────────────────────────────────────────────────────────

model GuardianCheck {
  id        String           @id @default(cuid())
  type      String
  status    GuardianStatus   @default(HEALTHY)
  severity  GuardianSeverity @default(INFO)
  message   String
  details   Json?
  duration  Int?
  createdAt DateTime         @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model GuardianIssue {
  id             String           @id @default(cuid())
  type           String
  severity       GuardianSeverity @default(WARNING)
  status         GuardianIssueStatus @default(OPEN)
  title          String
  description    String?
  source         String
  metadata       Json?
  autoRepairable Boolean          @default(false)
  repairedAt     DateTime?
  createdAt      DateTime         @default(now())

  repairs GuardianRepair[]

  @@index([type])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

model GuardianRepair {
  id        String   @id @default(cuid())
  issueId   String
  action    String
  success   Boolean  @default(false)
  message   String?
  details   Json?
  createdAt DateTime @default(now())

  issue GuardianIssue @relation(fields: [issueId], references: [id])

  @@index([issueId])
  @@index([createdAt])
}

model GuardianLog {
  id        String   @id @default(cuid())
  level     String   @default("INFO")
  source    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([source])
  @@index([createdAt])
}

enum GuardianStatus {
  HEALTHY
  DEGRADED
  BROKEN
  REPAIRED
  NEEDS_MANUAL_ACTION
}

enum GuardianSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum GuardianIssueStatus {
  OPEN
  REPAIRED
  IGNORED
  MANUAL_REQUIRED
}

// ─── CHARGEBACK DEFENDER ────────────────────────────────────────────────────

model PaymentEvidence {
  id                      String    @id @default(cuid())
  transactionId           String?
  stripePaymentIntentId   String?   @unique
  stripeCheckoutSessionId String?
  stripeChargeId          String?
  payerEmail              String?
  payerName               String?
  amount                  Int
  currency                String    @default("EUR")
  recipientAdminId        String
  description             String?
  ipAddress               String?
  userAgent               String?
  termsAccepted           Boolean   @default(false)
  refundPolicyAccepted    Boolean   @default(false)
  termsVersion            String    @default("1.0")
  refundPolicyVersion     String    @default("1.0")
  consentAt               DateTime?
  paymentStatus           String    @default("pending")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  deliveryProof PaymentDeliveryProof?
  risk          PaymentRisk?
  dispute       StripeDispute?
  alerts        AdminAlert[]

  @@index([stripePaymentIntentId])
  @@index([payerEmail])
  @@index([recipientAdminId])
  @@index([paymentStatus])
  @@index([createdAt])
}

model PaymentDeliveryProof {
  id                    String   @id @default(cuid())
  paymentEvidenceId     String   @unique
  stripePaymentIntentId String?
  stripeChargeId        String?
  deliveredAt           DateTime @default(now())
  webhookConfirmed      Boolean  @default(false)
  successPageViewed     Boolean  @default(false)
  receiptSent           Boolean  @default(false)
  metadata              Json?
  createdAt             DateTime @default(now())

  evidence PaymentEvidence @relation(fields: [paymentEvidenceId], references: [id])

  @@index([stripePaymentIntentId])
}

model PaymentRisk {
  id                String   @id @default(cuid())
  paymentEvidenceId String   @unique
  score             Int      @default(0)
  level             RiskLevel @default(LOW)
  reasons           Json
  createdAt         DateTime @default(now())

  evidence PaymentEvidence @relation(fields: [paymentEvidenceId], references: [id])

  @@index([level])
  @@index([score])
  @@index([createdAt])
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model StripeDispute {
  id                String    @id @default(cuid())
  stripeDisputeId   String    @unique
  stripeChargeId    String?
  paymentEvidenceId String?   @unique
  amount            Int
  currency          String    @default("EUR")
  reason            String?
  status            String    @default("needs_response")
  evidenceDueBy     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  evidence PaymentEvidence? @relation(fields: [paymentEvidenceId], references: [id])

  @@index([stripeDisputeId])
  @@index([status])
  @@index([createdAt])
}

model AdminAlert {
  id                String   @id @default(cuid())
  type              String
  severity          String   @default("INFO")
  title             String
  message           String
  paymentEvidenceId String?
  read              Boolean  @default(false)
  createdAt         DateTime @default(now())

  evidence PaymentEvidence? @relation(fields: [paymentEvidenceId], references: [id])

  @@index([type])
  @@index([read])
  @@index([createdAt])
}

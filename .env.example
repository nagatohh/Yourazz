# ╔══════════════════════════════════════════════════════════╗
# ║  Yourazz — Variables d'environnement                      ║
# ║  Copier vers .env (local) ou Vercel → Settings → Env Vars ║
# ╚══════════════════════════════════════════════════════════╝

# ─── Base de données (PostgreSQL : Neon, Supabase, Railway…) ─
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth (JWT maison — équivalent NEXTAUTH_SECRET) ──────────
# Générer : openssl rand -hex 32
JWT_SECRET="generate-random-64-chars-here"

# ─── App ─────────────────────────────────────────────────────
# URL publique du site (équivalent APP_URL / NEXTAUTH_URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Fournisseur de paiement ─────────────────────────────────
# "mock" pour le dev local, "stripe" en production
PAYMENT_PROVIDER="mock"

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Secret de signature du webhook (Dashboard Stripe → Webhooks)
STRIPE_WEBHOOK_SECRET=""

# ─── PayPlug (optionnel, fournisseur alternatif) ─────────────
PAYPLUG_SECRET_KEY=""
PAYPLUG_PUBLIC_KEY=""

# ─── Open Banking (optionnel) ────────────────────────────────
OPEN_BANKING_PROVIDER="mock"

# ─── Admin ───────────────────────────────────────────────────
# Emails admin séparés par des virgules
ADMIN_EMAILS="admin@yourazz.xyz"

# ─── Chiffrement (IBAN) ──────────────────────────────────────
# Générer : openssl rand -hex 32  (64 caractères hexadécimaux)
ENCRYPTION_KEY="generate-64-hex-characters-here"

# ─── Cron Vercel (protège /api/cron/guardian) ────────────────
# Générer : openssl rand -hex 24
CRON_SECRET="generate-random-string-here"

# ─── Emails transactionnels (Resend) ─────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Yourazz <noreply@yourazz.xyz>"

# ─── Abonnements en cryptomonnaie (Litecoin) ─────────────────
# Adresse LTC de réception affichée sur /access/crypto (avec QR code)
LTC_ADDRESS=""
# Montants LTC par plan (ajuster au cours réel du LTC). Vide = montant libre.
LTC_PRICE_PRO=""
LTC_PRICE_BUSINESS=""
# Adresses distinctes par plan (optionnel ; sinon LTC_ADDRESS est utilisée)
LTC_ADDRESS_PRO=""
LTC_ADDRESS_BUSINESS=""

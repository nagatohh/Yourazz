# Database (PostgreSQL - Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth
JWT_SECRET="generate-random-64-chars-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Payment Provider: "mock" pour dev, "payplug" pour production
PAYMENT_PROVIDER="mock"

# ─── PayPlug (payplug.com) ──────────────────────────────────
# Clé secrète (sk_test_... pour sandbox, sk_live_... pour production)
PAYPLUG_SECRET_KEY=""
# Clé publique pour vérification des webhooks (optionnel, format PEM)
PAYPLUG_PUBLIC_KEY=""

# ─── Open Banking (TrueLayer, GoCardless, Yapily) ───────────
OPEN_BANKING_PROVIDER="mock"
# TRUELAYER_CLIENT_ID=""
# TRUELAYER_CLIENT_SECRET=""
# GOCARDLESS_SECRET_ID=""
# GOCARDLESS_SECRET_KEY=""

# Webhook Security
WEBHOOK_SECRET="generate-random-string"

# Admin
ADMIN_EMAILS="admin@yourazz.com"
